<Project Sdk="Microsoft.NET.Sdk">

<PropertyGroup>
<!-- Vendored for CADability with strong-name signing - v3.0.8 -->
<TargetFramework>netstandard2.0</TargetFramework>
<LangVersion>9.0</LangVersion>
<Nullable>enable</Nullable>

<Authors>DomCr</Authors>
<Copyright>Copyright (c) 2022 Albert Domenech</Copyright>
<Description>C# library to read/write cad files like dxf/dwg. (Vendored v3.0.8 in CADability with strong-name signing)</Description>

<!-- Strong-name signing with CADability's key -->
<SignAssembly>True</SignAssembly>
<AssemblyOriginatorKeyFile>../../CADabilityKey.snk</AssemblyOriginatorKeyFile>

<!-- Disable package generation -->
<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
<IsPackable>False</IsPackable>

<!-- Disable documentation file generation to avoid warnings -->
<GenerateDocumentationFile>False</GenerateDocumentationFile>
</PropertyGroup>

<!-- Import shared projects from CSUtilities -->
<Import Project="..\CSUtilities\CSMath\CSMath.projitems" Label="Shared" />
<Import Project="..\CSUtilities\CSUtilities\CSUtilities.projitems" Label="Shared" />

<ItemGroup>
<PackageReference Include="System.Memory" Version="4.6.3" />
<PackageReference Include="System.Text.Encoding.CodePages" Version="9.0.6" />
</ItemGroup>

</Project>
